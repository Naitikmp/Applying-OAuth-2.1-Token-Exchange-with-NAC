# Auth0 Integration — Environment Variables
# -----------------------------------------
# 1. Copy this file to .env.auth0
# 2. Fill in YOUR values (see AUTH0_SETUP.md for where to find each one)
# 3. Load in bash/Git Bash:     set -a && source .env.auth0 && set +a
#    Load in PowerShell:         Get-Content .env.auth0 | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

# Auth0 tenant domain  (Dashboard → Applications → your app → Settings → Domain)
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com

# M2M application credentials  (Dashboard → Applications → your M2M app → Settings)
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET

# API resource identifier  (Dashboard → Applications → APIs → your API → Identifier)
AUTH0_HUB_AUDIENCE=https://mcp-hub.example.com

# Scopes your API exposes  (must be created under the API's Permissions tab)
AUTH0_ROOT_SCOPES=calendar:read docs:read comms:send external:fetch

# Optional: custom Redis URL (default: redis://127.0.0.1:6379/0)
# NAC_REDIS_URL=redis://127.0.0.1:6379/0

# Optional: custom ports for Auth0 stack (default: 9400-9405)
# AUTH0_EXCHANGE_PORT=9400
